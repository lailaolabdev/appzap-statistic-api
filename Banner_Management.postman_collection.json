            "url": {
              "raw": "{{baseUrl}}/api/v1/banners/placement/market_top",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "banners", "placement", "market_top"]
            }
          }
        },
        {
          "name": "Track Impression",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/banners/{{bannerId}}/impression",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "banners", "{{bannerId}}", "impression"]
            }
          }
        },
        {
          "name": "Track Click",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/banners/{{bannerId}}/click",
              "host": ["{{baseUrl}}"],
