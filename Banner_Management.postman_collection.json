            "url": {
              "raw": "{{baseUrl}}/api/v1/banners/placement/home_top",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "banners", "placement", "home_top"]
            }
          }
        },
        {
          "name": "Get Banners - Home Carousel",
          "request": {
