{
	"info": {
		"name": "Ads Management API",
		"description": "Ads Management CRUD API - proxied to Consumer API (server-to-server)",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:5050",
			"type": "string"
		},
		{
			"key": "adminKey",
			"value": "c89042be847246eb3ae2ed4c9c3ed02d5fd9981103b9fda7644a03722b7672f4",
			"type": "string"
		},
		{
			"key": "adId",
			"value": "",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "1. Upload Images",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "x-admin-key",
						"value": "{{adminKey}}"
					}
				],
				"body": {
					"mode": "formdata",
					"formdata": [
						{
							"key": "images",
							"type": "file",
							"src": "",
							"description": "Select image file (JPG, PNG, GIF, WebP - max 5MB)"
						},
						{
							"key": "images",
							"type": "file",
							"src": "",
							"description": "Select second image file (optional)"
						}
					]
				},
				"url": {
					"raw": "{{baseUrl}}/api/v1/ads-management/upload",
					"host": ["{{baseUrl}}"],
					"path": ["api", "v1", "ads-management", "upload"]
				},
				"description": "Upload multiple images for ads (up to 5 images, max 5MB each). Returns S3 URLs to use when creating ads."
			},
			"response": []
		},
		{
			"name": "2. Create Ad",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"var jsonData = pm.response.json();",
							"if (jsonData.success && jsonData.data && jsonData.data._id) {",
							"    pm.collectionVariables.set('adId', jsonData.data._id);",
							"    console.log('Saved adId:', jsonData.data._id);",
							"}"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "x-admin-key",
						"value": "{{adminKey}}"
					},
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"name\": \"Heineken Summer Campaign\",\n  \"description\": \"Summer promotion for Heineken 0.0\",\n  \"type\": \"banner\",\n  \"placement\": \"eat_hero_banner\",\n  \"advertiser\": {\n    \"name\": \"Heineken\",\n    \"companyName\": \"Heineken Laos Co., Ltd\",\n    \"phone\": \"+856 20 1234 5678\",\n    \"email\": \"marketing@heineken.la\"\n  },\n  \"content\": {\n    \"imageUrl\": \"https://appzap-assets.s3.amazonaws.com/ads/sample-banner.jpg\",\n    \"imageUrlMobile\": \"https://appzap-assets.s3.amazonaws.com/ads/sample-mobile.jpg\",\n    \"title\": \"Heineken 0.0 - Now Available\",\n    \"subtitle\": \"Order now and get 20% off\",\n    \"ctaText\": \"Order Now\",\n    \"ctaUrl\": \"appzap://restaurant/123\"\n  },\n  \"targeting\": {\n    \"provinces\": [\"Vientiane\", \"Luang Prabang\"],\n    \"languages\": [\"en\", \"lo\"]\n  },\n  \"schedule\": {\n    \"startDate\": \"2026-06-01T00:00:00Z\",\n    \"endDate\": \"2026-08-31T23:59:59Z\"\n  },\n  \"pricing\": {\n    \"type\": \"cpm\",\n    \"amount\": 50000,\n    \"currency\": \"LAK\"\n  },\n  \"priority\": 90,\n  \"weight\": 80\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/api/v1/ads-management",
					"host": ["{{baseUrl}}"],
					"path": ["api", "v1", "ads-management"]
				},
				"description": "Create a new advertisement. The adId is auto-saved to collection variables for use in subsequent requests."
			},
			"response": []
		},
		{
			"name": "3. Get All Ads",
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "x-admin-key",
						"value": "{{adminKey}}"
					}
				],
				"url": {
					"raw": "{{baseUrl}}/api/v1/ads-management?limit=20&skip=0",
					"host": ["{{baseUrl}}"],
					"path": ["api", "v1", "ads-management"],
					"query": [
						{
							"key": "status",
							"value": "pending_approval",
							"disabled": true
						},
						{
							"key": "type",
							"value": "banner",
							"disabled": true
						},
						{
							"key": "placement",
							"value": "eat_hero_banner",
							"disabled": true
						},
						{
							"key": "limit",
							"value": "20"
						},
						{
							"key": "skip",
							"value": "0"
						}
					]
				},
				"description": "Get all ads with optional filters. Enable/disable query params as needed."
			},
			"response": []
		},
		{
			"name": "4. Get Ad by ID",
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "x-admin-key",
						"value": "{{adminKey}}"
					}
				],
				"url": {
					"raw": "{{baseUrl}}/api/v1/ads-management/{{adId}}",
					"host": ["{{baseUrl}}"],
					"path": ["api", "v1", "ads-management", "{{adId}}"]
				},
				"description": "Get a single ad by ID. Uses the adId saved from Create Ad."
			},
			"response": []
		},
		{
			"name": "5. Update Ad",
			"request": {
				"method": "PUT",
				"header": [
					{
						"key": "x-admin-key",
						"value": "{{adminKey}}"
					},
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"name\": \"Updated Campaign Name\",\n  \"content\": {\n    \"title\": \"Updated Title\",\n    \"subtitle\": \"Updated subtitle text\"\n  },\n  \"status\": \"active\"\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/api/v1/ads-management/{{adId}}",
					"host": ["{{baseUrl}}"],
					"path": ["api", "v1", "ads-management", "{{adId}}"]
				},
				"description": "Update an existing ad. All fields are optional (partial update)."
			},
			"response": []
		},
		{
			"name": "6. Delete Ad",
			"request": {
				"method": "DELETE",
				"header": [
					{
						"key": "x-admin-key",
						"value": "{{adminKey}}"
					}
				],
				"url": {
					"raw": "{{baseUrl}}/api/v1/ads-management/{{adId}}",
					"host": ["{{baseUrl}}"],
					"path": ["api", "v1", "ads-management", "{{adId}}"]
				},
				"description": "Delete an ad permanently."
			},
			"response": []
		}
	]
}
