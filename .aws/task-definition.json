{
  "family": "appzap-statistic-api",
  "executionRoleArn": "arn:aws:iam::590183678522:role/ecsTaskExecutionRole",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "runtimePlatform": {
    "cpuArchitecture": "X86_64",
    "operatingSystemFamily": "LINUX"
  },
  "containerDefinitions": [
    {
      "name": "appzap-statistic-api",
      "image": "590183678522.dkr.ecr.ap-southeast-1.amazonaws.com/appzap/appzap-statistic-api:latest",
      "cpu": 0,
      "portMappings": [
        {
          "name": "appzap-statistic-api-5050-tcp",
          "containerPort": 5050,
          "hostPort": 5050,
          "protocol": "tcp",
          "appProtocol": "http"
        }
      ],
      "essential": true,
      "environment": [
        {
          "name": "PORT",
          "value": "5050"
        },
        {
          "name": "MONGODB_URI",
          "value": "mongodb+srv://appzap-ec2-prod-v2:G930sGWPwMmgGzzp@prod-v2.y9q2f.mongodb.net/AppZap?retryWrites=true&w=majority"
        },
        {
          "name": "MONGODB_URI_POS_V1",
          "value": "mongodb+srv://appzap-ec2-prod-v2:G930sGWPwMmgGzzp@prod-v2.y9q2f.mongodb.net/AppZap?retryWrites=true&w=majority"
        },
        {
          "name": "POS_V1_DB_NAME",
          "value": "AppZap"
        },
        {
          "name": "MONGODB_URI_POS_V2",
          "value": "mongodb+srv://appzap-ec2-prod-v2:G930sGWPwMmgGzzp@prod-v2.y9q2f.mongodb.net/AppZap?retryWrites=true&w=majority"
        },
        {
          "name": "POS_V2_DB_NAME",
          "value": "AppZap"
        },
        {
          "name": "NODE_ENV",
          "value": "production"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/appzap-statistic-api",
          "mode": "non-blocking",
          "awslogs-create-group": "true",
          "max-buffer-size": "25m",
          "awslogs-region": "ap-southeast-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
